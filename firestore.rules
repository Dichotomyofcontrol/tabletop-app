// ============================================================
// Tabletop Scheduler — Firestore security rules
//
// All app data access happens server-side via the Firebase Admin SDK,
// which bypasses these rules. They exist as defense-in-depth: if anyone
// connects the client SDK directly, they get nothing back except their
// own profile.
//
// Paste this entire file into:
//   Firebase console → Firestore Database → Rules → Publish
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/update only their own profile doc.
    match /users/{uid} {
      allow read, update: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Everything else is server-only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
